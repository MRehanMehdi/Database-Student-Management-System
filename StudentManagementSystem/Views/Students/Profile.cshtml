@* Student/Profile.cshtml *@
@model StudentManagementSystem.Models.Student
@{
    ViewBag.Title = "My Profile";
    ViewBag.ActivePage = "Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">My Profile</div>
        <div class="page-subtitle">// Your student record</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:260px 1fr;gap:20px;align-items:start">
    <div>
        <div class="profile-hero">
            @if (!string.IsNullOrEmpty(Model.PhotoPath))
            {
                <img src="@Url.Content(Model.PhotoPath)" class="profile-photo" style="margin:0 auto 14px;display:block" />
            }
            else
            {
                <div class="profile-photo-placeholder">@Model.FirstName.Substring(0, 1).ToUpper()</div>
            }
            <div class="profile-name">@Model.FirstName @Model.LastName</div>
            <div class="profile-email">@Model.Email</div>
            <div class="profile-meta">
                <div class="profile-meta-item">
                    <div class="meta-val">@(Model.Enrollments != null ? Model.Enrollments.Count : 0)</div>
                    <div class="meta-lbl">Courses</div>
                </div>
                <div class="profile-meta-item">
                    <div class="meta-val">#@Model.Id.ToString("D4")</div>
                    <div class="meta-lbl">Student ID</div>
                </div>
            </div>
        </div>
        <a href="@Url.Action("RegisterCourse","Student")" class="btn-edu btn-edu-primary w-100" style="justify-content:center">
            <i class="bi bi-plus-circle-fill"></i> Enroll in Course
        </a>
    </div>

    <div class="edu-card">
        <div class="edu-card-header">
            <span class="edu-card-title"><i class="bi bi-card-text me-2 text-teal"></i>Personal Details</span>
            <span class="badge-edu badge-teal"><i class="bi bi-circle-fill" style="font-size:0.45rem"></i> Active</span>
        </div>
        <div class="edu-card-body">
            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">First Name</div>
                    <div class="info-value">@Model.FirstName</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Last Name</div>
                    <div class="info-value">@Model.LastName</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Email</div>
                    <div class="info-value" style="font-size:0.82rem">@Model.Email</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Phone</div>
                    <div class="info-value mono">@Model.PhoneNumber</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Date of Birth</div>
                    <div class="info-value mono">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Student ID</div>
                    <div class="info-value mono">#@Model.Id.ToString("D5")</div>
                </div>
                <div class="info-item" style="grid-column:1/-1">
                    <div class="info-label">Address</div>
                    <div class="info-value">@Model.Address</div>
                </div>
            </div>
        </div>
    </div>
</div>
