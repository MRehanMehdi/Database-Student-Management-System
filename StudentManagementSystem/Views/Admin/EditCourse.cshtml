@model StudentManagementSystem.Models.Course
@{
    ViewBag.Title = "Edit Course";
    ViewBag.ActivePage = "Courses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Edit Course</div>
        <div class="page-subtitle">// Updating: @Model.CourseName</div>
    </div>
    <a href="@Url.Action("Courses","Admin")" class="btn-edu btn-edu-secondary">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:680px">
    @using (Html.BeginForm("EditCourse", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        <div class="edu-card mb-3">
            <div class="edu-card-header">
                <span class="edu-card-title"><i class="bi bi-book-half me-2 text-teal"></i>Course Details</span>
                <span class="badge-edu badge-blue">@Model.CourseCode</span>
            </div>
            <div class="edu-card-body">
                <div class="form-grid">
                    <div class="field-group">
                        <label class="field-label">Course Code *</label>
                        @Html.TextBoxFor(m => m.CourseCode, new { @class = "edu-input" })
                        @Html.ValidationMessageFor(m => m.CourseCode, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group">
                        <label class="field-label">Credit Hours *</label>
                        @Html.TextBoxFor(m => m.CreditHours, new { @class = "edu-input", type = "number", min = "1", max = "6" })
                        @Html.ValidationMessageFor(m => m.CreditHours, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group form-grid-full">
                        <label class="field-label">Course Name *</label>
                        @Html.TextBoxFor(m => m.CourseName, new { @class = "edu-input" })
                        @Html.ValidationMessageFor(m => m.CourseName, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group form-grid-full">
                        <label class="field-label">Instructor *</label>
                        @Html.TextBoxFor(m => m.Instructor, new { @class = "edu-input" })
                        @Html.ValidationMessageFor(m => m.Instructor, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group form-grid-full">
                        <label class="field-label">Description</label>
                        @Html.TextAreaFor(m => m.Description, new { @class = "edu-textarea" })
                    </div>
                </div>
            </div>
        </div>

        <div style="display:flex;gap:10px">
            <button type="submit" class="btn-edu btn-edu-primary">
                <i class="bi bi-check-lg"></i> Save Changes
            </button>
            <a href="@Url.Action("Courses","Admin")" class="btn-edu btn-edu-secondary">
                <i class="bi bi-x-lg"></i> Cancel
            </a>
        </div>
    }
</div>
