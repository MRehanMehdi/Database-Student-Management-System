@model StudentManagementSystem.Models.Student

@{
    ViewBag.Title = "Student Details";
}

<div class="container mt-4">
    <h2 class="text-center fw-bold text-primary mb-4">
        <i class="bi bi-person-badge-fill me-2"></i> Student Details
    </h2>

    <div class="card shadow-lg border-0 mx-auto" style="max-width: 750px; border-radius: 12px;">
        <div class="card-body p-4">
            <div class="row g-4 align-items-center">
                <!-- Student Photo -->
                <div class="col-md-4 text-center">
                    <img src="@Url.Content(Model.PhotoPath ?? "~/Images/default-student.png")"
                         alt="Student Photo"
                         class="rounded-circle border shadow-sm"
                         style="width: 180px; height: 180px; object-fit: cover;" />
                </div>

                <!-- Student Info -->
                <div class="col-md-8">
                    <table class="table table-borderless mb-0">
                        <tbody>
                            <tr>
                                <th class="text-muted" style="width: 35%;">Full Name:</th>
                                <td class="fw-semibold">@Model.FirstName @Model.LastName</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Email:</th>
                                <td>@Model.Email</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Phone:</th>
                                <td>@Model.PhoneNumber</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Date of Birth:</th>
                                <td>@Model.DateOfBirth.ToString("MMMM dd, yyyy")</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Address:</th>
                                <td>@Model.Address</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Footer with Actions -->
        <div class="card-footer bg-light text-center">
            <a href="@Url.Action("EditStudent", "Admin", new { id = Model.Id })"
               class="btn btn-outline-primary me-2">
                <i class="bi bi-pencil-square me-1"></i> Edit
            </a>
            <a href="@Url.Action("Students", "Admin")"
               class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle me-1"></i> Back to List
            </a>
        </div>
    </div>
</div>

<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
