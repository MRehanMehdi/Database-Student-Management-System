@model StudentManagementSystem.Models.Student
@{
    ViewBag.Title = "Student Profile";
    ViewBag.ActivePage = "Students";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Student Profile</div>
        <div class="page-subtitle">// Viewing record for ID #@Model.Id</div>
    </div>
    <div style="display:flex;gap:8px">
        <a href="@Url.Action("EditStudent","Admin", new { id = Model.Id })" class="btn-edu btn-edu-secondary">
            <i class="bi bi-pencil-fill"></i> Edit
        </a>
        <a href="@Url.Action("Students","Admin")" class="btn-edu btn-edu-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div style="display:grid;grid-template-columns:280px 1fr;gap:20px;align-items:start">

    <!-- Profile Card -->
    <div>
        <div class="profile-hero">
            @if (!string.IsNullOrEmpty(Model.PhotoPath))
            {
                <img src="@Url.Content(Model.PhotoPath)" alt="Photo" class="profile-photo" style="margin:0 auto 14px;display:block" />
            }
            else
            {
                <div class="profile-photo-placeholder">@Model.FirstName.Substring(0, 1).ToUpper()</div>
            }
            <div class="profile-name">@Model.FirstName @Model.LastName</div>
            <div class="profile-email">@Model.Email</div>
            <div class="profile-meta">
                <div class="profile-meta-item">
                    <div class="meta-val">@(Model.Enrollments != null ? Model.Enrollments.Count : 0)</div>
                    <div class="meta-lbl">Courses</div>
                </div>
                <div class="profile-meta-item">
                    <div class="meta-val">@((DateTime.Now - Model.DateOfBirth).Days / 365)</div>
                    <div class="meta-lbl">Age</div>
                </div>
            </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:8px">
            <a href="@Url.Action("EditStudent","Admin",new{id=Model.Id})" class="btn-edu btn-edu-primary w-100" style="justify-content:center">
                <i class="bi bi-pencil-fill"></i> Edit Profile
            </a>
            <a href="@Url.Action("StudentCourses","Admin",new{id=Model.Id})" class="btn-edu btn-edu-secondary w-100" style="justify-content:center">
                <i class="bi bi-book"></i> View Courses
            </a>
            <a href="@Url.Action("DeleteStudent","Admin",new{id=Model.Id})" class="btn-edu btn-edu-danger w-100" style="justify-content:center">
                <i class="bi bi-trash3-fill"></i> Delete
            </a>
        </div>
    </div>

    <!-- Details -->
    <div>
        <div class="edu-card mb-3">
            <div class="edu-card-header">
                <span class="edu-card-title"><i class="bi bi-card-text me-2 text-teal"></i>Personal Details</span>
                <span class="badge-edu badge-teal"><i class="bi bi-circle-fill" style="font-size:0.45rem"></i> Active</span>
            </div>
            <div class="edu-card-body">
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">First Name</div>
                        <div class="info-value">@Model.FirstName</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Last Name</div>
                        <div class="info-value">@Model.LastName</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Email Address</div>
                        <div class="info-value" style="font-size:0.82rem">@Model.Email</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Phone Number</div>
                        <div class="info-value mono">@Model.PhoneNumber</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Date of Birth</div>
                        <div class="info-value mono">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Student ID</div>
                        <div class="info-value mono">#@Model.Id.ToString("D5")</div>
                    </div>
                    <div class="info-item" style="grid-column:1/-1">
                        <div class="info-label">Address</div>
                        <div class="info-value">@Model.Address</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Enrolled Courses -->
        <div class="edu-card">
            <div class="edu-card-header">
                <span class="edu-card-title"><i class="bi bi-journal-check me-2 text-teal"></i>Enrolled Courses</span>
                <span class="badge-edu badge-blue">@(Model.Enrollments != null ? Model.Enrollments.Count : 0) course(s)</span>
            </div>
            <div class="edu-card-body">
                @if (Model.Enrollments != null && Model.Enrollments.Any())
                {
                    <div style="display:flex;flex-direction:column;gap:8px">
                        @foreach (var enr in Model.Enrollments)
                        {
                            <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 16px;display:flex;justify-content:space-between;align-items:center">
                                <div>
                                    <div style="font-weight:600;font-size:0.87rem">@(enr.Course != null ? enr.Course.CourseName : "Course")</div>
                                    <div class="mono" style="font-size:0.7rem;color:var(--text-dim)">Enrolled: @enr.EnrollmentDate.ToString("MMM dd, yyyy")</div>
                                </div>
                                <span class="badge-edu badge-teal">Enrolled</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state" style="padding:24px">
                        <i class="bi bi-book"></i>
                        <p>Not enrolled in any courses</p>
                    </div>
                }
            </div>
        </div>
    </div>

</div>
