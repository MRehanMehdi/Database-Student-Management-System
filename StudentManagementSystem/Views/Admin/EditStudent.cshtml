@model StudentManagementSystem.Models.Student
@{
    ViewBag.Title = "Edit Student";
    ViewBag.ActivePage = "Students";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Edit Student</div>
        <div class="page-subtitle">// Updating: @Model.FirstName @Model.LastName (ID #@Model.Id)</div>
    </div>
    <a href="@Url.Action("Students","Admin")" class="btn-edu btn-edu-secondary">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:760px">
    @using (Html.BeginForm("EditStudent", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)
        @Html.HiddenFor(m => m.PhotoPath)

        <div class="edu-card mb-3">
            <div class="edu-card-header">
                <span class="edu-card-title"><i class="bi bi-pencil-square me-2 text-teal"></i>Edit Information</span>
                <span class="badge-edu badge-blue">ID #@Model.Id</span>
            </div>
            <div class="edu-card-body">
                <div class="form-grid">
                    <div class="field-group">
                        <label class="field-label">First Name *</label>
                        @Html.TextBoxFor(m => m.FirstName, new { @class = "edu-input" })
                        @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group">
                        <label class="field-label">Last Name *</label>
                        @Html.TextBoxFor(m => m.LastName, new { @class = "edu-input" })
                        @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group">
                        <label class="field-label">Email Address *</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "edu-input" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group">
                        <label class="field-label">Phone Number *</label>
                        @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "edu-input" })
                        @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group">
                        <label class="field-label">Date of Birth *</label>
                        @Html.TextBoxFor(m => m.DateOfBirth, "{0:yyyy-MM-dd}", new { @class = "edu-input", type = "date" })
                        @Html.ValidationMessageFor(m => m.DateOfBirth, "", new { @class = "field-error" })
                    </div>
                    <div class="field-group">
                        <label class="field-label">Update Photo</label>
                        @if (!string.IsNullOrEmpty(Model.PhotoPath))
                        {
                            <img src="@Url.Content(Model.PhotoPath)" style="width:50px;height:50px;border-radius:10px;object-fit:cover;border:2px solid var(--border2);margin-bottom:8px;display:block" />
                        }
                        <input type="file" name="PhotoFile" class="edu-input" accept="image/*" />
                        <div class="field-hint">// Leave blank to keep current photo</div>
                    </div>
                    <div class="field-group form-grid-full">
                        <label class="field-label">Address *</label>
                        @Html.TextAreaFor(m => m.Address, new { @class = "edu-textarea" })
                        @Html.ValidationMessageFor(m => m.Address, "", new { @class = "field-error" })
                    </div>
                </div>
            </div>
        </div>

        <div style="display:flex;gap:10px">
            <button type="submit" class="btn-edu btn-edu-primary">
                <i class="bi bi-check-lg"></i> Save Changes
            </button>
            <a href="@Url.Action("Students","Admin")" class="btn-edu btn-edu-secondary">
                <i class="bi bi-x-lg"></i> Cancel
            </a>
        </div>
    }
</div>
