@model IEnumerable<StudentManagementSystem.Models.Student>
@{
    ViewBag.Title = "Students";
    ViewBag.ActivePage = "Students";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Student Records</div>
        <div class="page-subtitle">// @Model.Count() student(s) found</div>
    </div>
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        @using (Html.BeginForm("Students", "Admin", FormMethod.Get))
        {
            <div class="search-bar">
                <i class="bi bi-search"></i>
                <input type="text" name="searchString" value="@Request.QueryString["searchString"]" placeholder="Search by name..." />
            </div>
        }
        <a href="@Url.Action("CreateStudent","Admin")" class="btn-edu btn-edu-primary">
            <i class="bi bi-person-plus-fill"></i> Add Student
        </a>
        <a href="@Url.Action("GenerateStudentReport","Admin")" class="btn-edu btn-edu-secondary">
            <i class="bi bi-download"></i> Export CSV
        </a>
    </div>
</div>

<div class="edu-table-wrap">
    <table class="edu-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Student</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Date of Birth</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int i = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td style="font-family:'IBM Plex Mono',monospace;font-size:0.72rem;color:var(--text-dim)">@i</td>
                        <td>
                            <div class="student-cell">
                                @if (!string.IsNullOrEmpty(item.PhotoPath))
                                {
                                    <img src="@Url.Content(item.PhotoPath)" alt="Photo" class="student-avatar" />
                                }
                                else
                                {
                                    <div class="student-avatar-placeholder">
                                        @item.FirstName.Substring(0, 1).ToUpper()
                                    </div>
                                }
                                <div>
                                    <div class="student-name">@item.FirstName @item.LastName</div>
                                    <div class="student-id">ID #@item.Id</div>
                                </div>
                            </div>
                        </td>
                        <td style="font-size:0.82rem;color:var(--text-muted)">@item.Email</td>
                        <td>
                            <span class="mono" style="font-size:0.82rem;color:var(--text-muted)">@item.PhoneNumber</span>
                        </td>
                        <td>
                            <span class="mono" style="font-size:0.8rem;color:var(--text-muted)">@item.DateOfBirth.ToString("MMM dd, yyyy")</span>
                        </td>
                        <td>
                            <span class="badge-edu badge-teal"><i class="bi bi-circle-fill" style="font-size:0.45rem"></i> Active</span>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a href="@Url.Action("DetailStudent","Admin", new { id = item.Id })" class="btn-edu btn-edu-secondary btn-edu-sm btn-edu-icon" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="@Url.Action("EditStudent","Admin", new { id = item.Id })" class="btn-edu btn-edu-secondary btn-edu-sm btn-edu-icon" title="Edit">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <a href="@Url.Action("StudentCourses","Admin", new { id = item.Id })" class="btn-edu btn-edu-secondary btn-edu-sm btn-edu-icon" title="Courses">
                                    <i class="bi bi-book"></i>
                                </a>
                                <a href="@Url.Action("DeleteStudent","Admin", new { id = item.Id })" class="btn-edu btn-edu-danger btn-edu-sm btn-edu-icon" title="Delete">
                                    <i class="bi bi-trash3-fill"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    i++;
                }
            }
            else
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state">
                            <i class="bi bi-people"></i>
                            <h4>No students found</h4>
                            <p>Add your first student to get started</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
