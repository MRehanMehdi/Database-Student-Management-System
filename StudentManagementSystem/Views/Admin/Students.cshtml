@model IEnumerable<StudentManagementSystem.Models.Student>

@{
    ViewBag.Title = "Students";
}

<div class="container py-4">
    <h2 class="mb-4 text-primary fw-bold border-bottom pb-2">
        <i class="bi bi-people-fill"></i> Student Management
    </h2>

    <!-- Top Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            @Html.ActionLink("➕ Add New Student", "CreateStudent", null, new { @class = "btn btn-success fw-semibold shadow-sm" })
        </div>
        <!-- Search form -->
        @using (Html.BeginForm("Students", "Admin", FormMethod.Get))
        {
            <div class="input-group" style="max-width: 350px;">
                <input type="text" name="searchString" value="@Request.QueryString["searchString"]"
                       class="form-control border-primary shadow-sm"
                       placeholder="🔍 Search by name..." />
                <button type="submit" class="btn btn-primary shadow-sm">Search</button>
            </div>
        }
    </div>

    <!-- Table -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-bordered align-middle mb-2">
            <thead class="table-primary text-dark">
                <tr>
                    <th style="width: 90px;" class="text-center">Photo</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th style="width: 220px;" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="table-row-hover">
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.PhotoPath))
                                {
                                    <img src="@Url.Content(item.PhotoPath)" alt="Student Photo"
                                         class="rounded-circle border"
                                         style="width:65px; height:65px; object-fit: cover;" />
                                }
                                else
                                {
                                    <img src="@Url.Content("~/Images/default-student.png")" alt="No Photo"
                                         class="rounded-circle border"
                                         style="width:65px; height:65px; object-fit: cover;" />
                                }
                            </td>
                            <td class="fw-semibold">
                                @Html.DisplayFor(modelItem => item.FirstName)
                                @Html.DisplayFor(modelItem => item.LastName)
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.Email)</td>
                            <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                            <td class="text-center">
                                <div class="btn-group">
                                    @Html.ActionLink("✏ Edit", "EditStudent", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-primary" })
                                    @Html.ActionLink("ℹ Details", "DetailStudent", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-info" })
                                    @Html.ActionLink("🗑 Delete", "DeleteStudent", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-danger" })
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-emoji-frown"></i> No student records found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Extra Styling -->
<style>
    .table-row-hover:hover {
        background-color: #f1f7ff !important;
        transition: 0.2s ease-in-out;
    }
</style>
