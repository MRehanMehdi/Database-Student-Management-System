@model StudentManagementSystem.Models.Student

@{
    ViewBag.Title = "Delete Student";
}

<div class="container mt-4">
    <h2 class="text-center text-danger fw-bold mb-4">
        <i class="bi bi-trash3-fill me-2"></i> Delete Student
    </h2>

    <div class="alert alert-warning shadow-sm text-center fw-semibold" role="alert">
        ⚠️ Are you sure you want to delete this student? This action cannot be undone.
    </div>

    <!-- Student Card -->
    <div class="card shadow-lg border-0 mb-4">
        <div class="card-header bg-danger text-white fw-bold">
            Student Details
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-4 text-center">
                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="@Url.Content(Model.PhotoPath)" alt="Student Photo"
                             class="rounded-circle shadow border"
                             style="width: 150px; height: 150px; object-fit: cover;" />
                    }
                    else
                    {
                        <img src="@Url.Content("~/Images/default-student.png")" alt="No Photo"
                             class="rounded-circle shadow border"
                             style="width: 150px; height: 150px; object-fit: cover;" />
                    }
                </div>
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4">First Name</dt>
                        <dd class="col-sm-8">@Model.FirstName</dd>

                        <dt class="col-sm-4">Last Name</dt>
                        <dd class="col-sm-8">@Model.LastName</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Phone Number</dt>
                        <dd class="col-sm-8">@Model.PhoneNumber</dd>

                        <dt class="col-sm-4">Date of Birth</dt>
                        <dd class="col-sm-8">@Model.DateOfBirth.ToShortDateString()</dd>

                        <dt class="col-sm-4">Address</dt>
                        <dd class="col-sm-8">@Model.Address</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete & Cancel Buttons -->
    <div class="d-flex justify-content-center gap-3">
        <button type="button" class="btn btn-danger px-4" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
            <i class="bi bi-trash3-fill me-1"></i> Delete
        </button>
        <a href="@Url.Action("Students", "Admin")" class="btn btn-secondary px-4">
            <i class="bi bi-x-circle me-1"></i> Cancel
        </a>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold" id="confirmDeleteLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Deletion
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="fw-semibold">Are you absolutely sure you want to delete <span class="text-danger">"@Model.FirstName @Model.LastName"</span>?</p>
                <p class="text-muted">This action is permanent and cannot be undone.</p>
            </div>
            <div class="modal-footer d-flex justify-content-center">
                @using (Html.BeginForm("DeleteStudent", "Admin", new { id = Model.Id }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash3-fill me-1"></i> Yes, Delete
                    </button>
                }
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                    <i class="bi bi-arrow-left-circle me-1"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
