@model StudentManagementSystem.Models.Student
@{
    ViewBag.Title = "Delete Student";
    ViewBag.ActivePage = "Students";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="display:flex;align-items:center;justify-content:center;min-height:60vh">
    <div class="danger-card">
        <div class="danger-icon"><i class="bi bi-trash3-fill"></i></div>
        <h3 style="font-size:1.2rem;font-weight:800;color:var(--text);margin-bottom:8px">Delete Student?</h3>
        <p style="color:var(--text-muted);font-size:0.87rem;margin-bottom:20px">
            You are about to permanently delete the record for
            <strong style="color:var(--text)">@Model.FirstName @Model.LastName</strong>.
            This action cannot be undone.
        </p>

        <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:14px;margin-bottom:24px;text-align:left">
            <div style="display:flex;justify-content:space-between;margin-bottom:6px">
                <span class="mono" style="font-size:0.72rem;color:var(--text-dim)">EMAIL</span>
                <span style="font-size:0.82rem;color:var(--text-muted)">@Model.Email</span>
            </div>
            <div style="display:flex;justify-content:space-between">
                <span class="mono" style="font-size:0.72rem;color:var(--text-dim)">STUDENT ID</span>
                <span class="mono" style="font-size:0.82rem;color:var(--text-muted)">#@Model.Id.ToString("D5")</span>
            </div>
        </div>

        @using (Html.BeginForm("DeleteStudent", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div style="display:flex;gap:10px;justify-content:center">
                <button type="submit" class="btn-edu btn-edu-danger">
                    <i class="bi bi-trash3-fill"></i> Yes, Delete
                </button>
                <a href="@Url.Action("Students","Admin")" class="btn-edu btn-edu-secondary">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
            </div>
        }
    </div>
</div>
