@{
    ViewBag.Title = "Announcements";
    ViewBag.ActivePage = "Announcements";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Announcements</div>
        <div class="page-subtitle">// Broadcast notices to all students</div>
    </div>
    <a href="@Url.Action("CreateAnnouncement","Admin")" class="btn-edu btn-edu-primary">
        <i class="bi bi-plus-lg"></i> New Announcement
    </a>
</div>

@if (ViewBag.Announcements != null && ((IEnumerable<dynamic>)ViewBag.Announcements).Any())
{
    foreach (var ann in ViewBag.Announcements)
    {
        <div class="ann-card">
            <div class="ann-dot"></div>
            <div style="flex:1">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap">
                    <div>
                        <div class="ann-title">@ann.Title</div>
                        <div class="ann-body mt-1">@ann.Body</div>
                        <div class="ann-date">@ann.CreatedAt.ToString("MMMM dd, yyyy — hh:mm tt")</div>
                    </div>
                    <div style="display:flex;gap:6px;flex-shrink:0">
                        @if (ann.Category != null)
                        {
                            <span class="badge-edu badge-orange">@ann.Category</span>
                        }
                        <a href="@Url.Action("DeleteAnnouncement","Admin",new{id=ann.Id})" class="btn-edu btn-edu-danger btn-edu-sm btn-edu-icon"><i class="bi bi-trash3-fill"></i></a>
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="edu-card">
        <div class="empty-state">
            <i class="bi bi-megaphone"></i>
            <h4>No announcements yet</h4>
            <p>Post an announcement to notify students</p>
            <a href="@Url.Action("CreateAnnouncement","Admin")" class="btn-edu btn-edu-primary" style="margin-top:16px;display:inline-flex">
                <i class="bi bi-plus-lg"></i> Post First Announcement
            </a>
        </div>
    </div>
}
