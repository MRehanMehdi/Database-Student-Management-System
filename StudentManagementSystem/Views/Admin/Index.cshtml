@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="header-section text-center py-5 bg-primary bg-opacity-10 rounded-4 mb-5 position-relative">
    <div class="admin-avatar mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="#0d6efd" class="bi bi-shield-lock-fill" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.8 11.8 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.8 11.8 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0m0 5a1.5 1.5 0 0 1 .5 2.915l.5 1.5a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5l.5-1.5A1.5 1.5 0 0 1 8 5" />
        </svg>
    </div>
    <h1 class="display-4 fw-bold text-dark mb-3">Student Management Portal</h1>
    <p class="lead text-muted fs-5 mb-3">
        Comprehensive control over student records and academic data
    </p>

    <!-- Admin Dashboard Button

    <button onclick="location.href='@Url.Action("AdminProfile", "Admin")'" class="btn btn-primary px-4 py-2 fw-semibold rounded-pill">
        Admin Panel
    </button>
     -->
    <!-- Main Card -->
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card border-0 shadow-lg overflow-hidden">
                <div class="row g-0">
                    <!-- Left Side - Graphic -->
                    <div class="col-md-5 d-none d-md-flex bg-primary bg-opacity-5">
                        <div class="d-flex align-items-center justify-content-center h-100 p-4">
                            <img src="https://img.freepik.com/free-vector/student-with-laptop-studying-online-course_74855-5293.jpg" alt="Student Management" class="img-fluid rounded-3">
                        </div>
                    </div>

                    <!-- Right Side - Content -->
                    <div class="col-md-7">
                        <div class="card-body p-5">
                            <div class="d-flex align-items-center mb-4">
                                <div class="icon-wrapper bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#0d6efd" class="bi bi-people-fill" viewBox="0 0 16 16">
                                        <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5" />
                                    </svg>
                                </div>
                                <h2 class="h3 mb-0">Student Records</h2>
                            </div>

                            <p class="text-muted mb-4">
                                Manage all student information including personal details, academic records, enrollment status, and performance metrics. Perform bulk operations and generate detailed reports.
                            </p>

                            <div class="row g-3 mb-4">
                                <div class="col-6">
                                    <div class="d-flex align-items-center p-3 bg-light rounded-3 h-100">
                                        <div class="me-3 text-primary">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-person-plus" viewBox="0 0 16 16">
                                                <path d="M6 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H1s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C9.516 10.68 8.289 10 6 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z" />
                                                <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5" />
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-0">Add New</h3>
                                            <small class="text-muted">Register students</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="d-flex align-items-center p-3 bg-light rounded-3 h-100">
                                        <div class="me-3 text-success">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-0">Search</h3>
                                            <small class="text-muted">Find records</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="d-flex align-items-center p-3 bg-light rounded-3 h-100">
                                        <div class="me-3 text-warning">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-file-earmark-spreadsheet" viewBox="0 0 16 16">
                                                <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V9H3V2a1 1 0 0 1 1-1h5.5zM3 12v-2h2v2zm3 0v-2h3v2zm-3 1v2h2v-2zm3 0v2h3v-2zm4 0v2h2a1 1 0 0 0 1-1v-1zm0-3h2V9h-2zm0 1h2v2h-2z" />
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-0">Reports</h3>
                                            <small class="text-muted">Generate analytics</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="d-flex align-items-center p-3 bg-light rounded-3 h-100">
                                        <div class="me-3 text-danger">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-upload" viewBox="0 0 16 16">
                                                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5" />
                                                <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z" />
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-0">Import</h3>
                                            <small class="text-muted">Bulk upload</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid gap-3 d-sm-flex">
                                @Html.ActionLink("View All Students", "Students", "Admin", null, new { @class = "btn btn-primary px-4 py-3 flex-grow-1" })
                                <button class="btn btn-outline-primary px-4 py-3 flex-grow-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-download me-2" viewBox="0 0 16 16">
                                        <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5" />
                                        <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z" />
                                    </svg>
                                    Export Data
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-dashboard {
        background-color: #f8f9fa;
        min-height: calc(100vh - 56px);
        padding: 2rem 0;
    }

    .header-section {
        background: linear-gradient(135deg, rgba(13,110,253,0.1) 0%, rgba(255,255,255,1) 100%);
        border: 1px solid rgba(13,110,253,0.2);
    }

    .admin-avatar {
        width: 100px;
        height: 100px;
        background-color: rgba(13,110,253,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        border: 3px solid rgba(13,110,253,0.3);
    }

    .card {
        transition: all 0.3s ease;
        border-radius: 1rem;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important;
        }

    .icon-wrapper {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn {
        font-weight: 500;
        transition: all 0.2s;
    }

    .btn-primary {
        box-shadow: 0 4px 6px rgba(13,110,253,0.2);
    }

    .btn-outline-primary:hover {
        box-shadow: 0 4px 6px rgba(13,110,253,0.2);
    }
</style>