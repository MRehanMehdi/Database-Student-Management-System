@{
    ViewBag.Title = "Dashboard";
    ViewBag.ActivePage = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Stat Cards -->
<div class="stat-grid">
    <div class="stat-card stat-teal">
        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
        <div class="stat-info">
            <div class="stat-val">@ViewBag.TotalStudents</div>
            <div class="stat-label">Total Students</div>
            <div class="stat-change">↑ Active Records</div>
        </div>
    </div>
    <div class="stat-card stat-blue">
        <div class="stat-icon"><i class="bi bi-book-fill"></i></div>
        <div class="stat-info">
            <div class="stat-val">@ViewBag.TotalCourses</div>
            <div class="stat-label">Total Courses</div>
            <div class="stat-change">↑ Available</div>
        </div>
    </div>
    <div class="stat-card stat-purple">
        <div class="stat-icon"><i class="bi bi-journal-check"></i></div>
        <div class="stat-info">
            <div class="stat-val">@ViewBag.TotalEnrollments</div>
            <div class="stat-label">Enrollments</div>
            <div class="stat-change">↑ This Semester</div>
        </div>
    </div>
    <div class="stat-card stat-orange">
        <div class="stat-icon"><i class="bi bi-megaphone-fill"></i></div>
        <div class="stat-info">
            <div class="stat-val">@ViewBag.TotalAnnouncements</div>
            <div class="stat-label">Announcements</div>
            <div class="stat-change">↑ Posted</div>
        </div>
    </div>
</div>

<div class="row" style="display:grid;grid-template-columns:1fr 1fr;gap:20px">

    <!-- Recent Students -->
    <div class="edu-card">
        <div class="edu-card-header">
            <span class="edu-card-title"><i class="bi bi-people me-2 text-teal"></i>Recent Students</span>
            <a href="@Url.Action("Students","Admin")" class="btn-edu btn-edu-secondary btn-edu-sm">View All</a>
        </div>
        <div class="edu-table-wrap" style="border:none;border-radius:0">
            <table class="edu-table">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Email</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.RecentStudents != null)
                    {
                        foreach (var s in ViewBag.RecentStudents)
                        {
                            <tr>
                                <td>
                                    <div class="student-cell">
                                        <div class="student-avatar-placeholder">
                                            @s.FirstName.ToString().Substring(0,1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="student-name">@s.FirstName @s.LastName</div>
                                            <div class="student-id">ID #@s.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-size:0.8rem;color:var(--text-muted)">@s.Email</td>
                                <td>
                                    <a href="@Url.Action("DetailStudent","Admin", new { id = s.Id })" class="btn-edu btn-edu-secondary btn-edu-sm btn-edu-icon">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3"><div class="empty-state"><i class="bi bi-people"></i><p>No students yet</p></div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Announcements -->
    <div class="edu-card">
        <div class="edu-card-header">
            <span class="edu-card-title"><i class="bi bi-megaphone me-2 text-teal"></i>Announcements</span>
            <a href="@Url.Action("Announcements","Admin")" class="btn-edu btn-edu-secondary btn-edu-sm">Manage</a>
        </div>
        <div class="edu-card-body">
            @if (ViewBag.RecentAnnouncements != null && ((IEnumerable<dynamic>)ViewBag.RecentAnnouncements).Any())
            {
                foreach (var ann in ViewBag.RecentAnnouncements)
                {
                    <div class="ann-card">
                        <div class="ann-dot"></div>
                        <div>
                            <div class="ann-title">@ann.Title</div>
                            <div class="ann-body">@ann.Body</div>
                            <div class="ann-date">@ann.CreatedAt.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-megaphone"></i>
                    <h4>No announcements</h4>
                    <p>Post one to notify students</p>
                </div>
            }
            <a href="@Url.Action("CreateAnnouncement","Admin")" class="btn-edu btn-edu-primary w-100 mt-2" style="justify-content:center">
                <i class="bi bi-plus-lg"></i> New Announcement
            </a>
        </div>
    </div>

</div>

<!-- Quick Actions -->
<div class="edu-card mt-3" style="margin-top:20px">
    <div class="edu-card-header">
        <span class="edu-card-title"><i class="bi bi-lightning-fill me-2 text-teal"></i>Quick Actions</span>
    </div>
    <div class="edu-card-body" style="display:flex;gap:12px;flex-wrap:wrap">
        <a href="@Url.Action("CreateStudent","Admin")" class="btn-edu btn-edu-primary">
            <i class="bi bi-person-plus-fill"></i> Add Student
        </a>
        <a href="@Url.Action("CreateCourse","Admin")" class="btn-edu btn-edu-secondary">
            <i class="bi bi-book-half"></i> Add Course
        </a>
        <a href="@Url.Action("Grades","Admin")" class="btn-edu btn-edu-secondary">
            <i class="bi bi-award"></i> Manage Grades
        </a>
        <a href="@Url.Action("GenerateStudentReport","Admin")" class="btn-edu btn-edu-secondary">
            <i class="bi bi-file-earmark-arrow-down"></i> Export CSV
        </a>
        <a href="@Url.Action("StudentReport","Admin")" class="btn-edu btn-edu-secondary">
            <i class="bi bi-bar-chart"></i> View Report
        </a>
    </div>
</div>
