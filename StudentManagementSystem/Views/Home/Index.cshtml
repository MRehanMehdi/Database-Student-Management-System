@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid admin-dashboard">
    <!-- Header Section -->
    <div class="header-section text-center py-5 rounded-4 mb-5 shadow-sm">
        <div class="admin-avatar mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="#0d6efd" class="bi bi-shield-lock-fill" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.8 11.8 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.8 11.8 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0m0 5a1.5 1.5 0 0 1 .5 2.915l.5 1.5a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5l.5-1.5A1.5 1.5 0 0 1 8 5" />
            </svg>
        </div>
        <h1 class="display-5 fw-bold text-dark mb-3">Student Management Portal</h1>
        <p class="lead text-muted fs-5 mb-0">
            Manage student records efficiently with a clean and user-friendly interface
        </p>
    </div>

    <!-- Main Card -->
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card border-0 shadow-lg overflow-hidden rounded-4">
                <div class="row g-0">
                    <!-- Left Side - Graphic -->
                    <div class="col-md-5 d-none d-md-flex bg-primary bg-opacity-10">
                        <div class="d-flex align-items-center justify-content-center h-100 p-4">
                            <img src="https://img.freepik.com/free-vector/student-with-laptop-studying-online-course_74855-5293.jpg"
                                 alt="Student Management" class="img-fluid rounded-3 shadow-sm">
                        </div>
                    </div>

                    <!-- Right Side - Content -->
                    <div class="col-md-7">
                        <div class="card-body p-5">
                            <div class="d-flex align-items-center mb-4">
                                <div class="icon-wrapper bg-primary bg-opacity-10 p-3 rounded-circle me-3 shadow-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#0d6efd" class="bi bi-people-fill" viewBox="0 0 16 16">
                                        <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5" />
                                    </svg>
                                </div>
                                <h2 class="h3 mb-0">Student Records</h2>
                            </div>

                            <p class="text-muted mb-4">
                                Easily create, search, update, or delete student records. Keep everything organized with a professional dashboard.
                            </p>

                            <!-- Action Cards -->
                            <div class="row g-3 mb-4">
                                <div class="col-6">
                                    <div class="action-card d-flex align-items-center p-3 bg-light rounded-3 h-100 shadow-sm">
                                        <div class="me-3 text-primary fs-5">
                                            <i class="bi bi-person-plus"></i>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-0">Add New</h3>
                                            <small class="text-muted">Register student</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="action-card d-flex align-items-center p-3 bg-light rounded-3 h-100 shadow-sm">
                                        <div class="me-3 text-success fs-5">
                                            <i class="bi bi-search"></i>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-0">Search</h3>
                                            <small class="text-muted">Find records</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="action-card d-flex align-items-center p-3 bg-light rounded-3 h-100 shadow-sm">
                                        <div class="me-3 text-warning fs-5">
                                            <i class="bi bi-file-earmark-spreadsheet"></i>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-0">Reports</h3>
                                            <small class="text-muted">Generate reports</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="action-card d-flex align-items-center p-3 bg-light rounded-3 h-100 shadow-sm">
                                        <div class="me-3 text-danger fs-5">
                                            <i class="bi bi-upload"></i>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-0">Import</h3>
                                            <small class="text-muted">Bulk upload</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="d-grid gap-3 d-sm-flex">
                                @Html.ActionLink("View All Students", "Students", "Admin", null, new { @class = "btn btn-primary px-4 py-3 flex-grow-1 shadow-sm" })
                                <button class="btn btn-outline-primary px-4 py-3 flex-grow-1 shadow-sm">
                                    <i class="bi bi-download me-2"></i> Export Data
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-dashboard {
        background-color: #f8f9fa;
        min-height: calc(100vh - 56px);
        padding: 2rem 0;
    }

    .header-section {
        background: linear-gradient(135deg, rgba(13,110,253,0.08) 0%, rgba(255,255,255,1) 100%);
        border: 1px solid rgba(13,110,253,0.2);
    }

    .admin-avatar {
        width: 100px;
        height: 100px;
        background-color: rgba(13,110,253,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        border: 3px solid rgba(13,110,253,0.3);
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .card {
        border-radius: 1rem;
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,0.1) !important;
        }

    .icon-wrapper {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .action-card {
        transition: background-color 0.2s ease, transform 0.2s ease;
        cursor: pointer;
    }

        .action-card:hover {
            background-color: #eef5ff;
            transform: translateY(-3px);
        }

    .btn {
        font-weight: 500;
        border-radius: 0.6rem;
    }

    .btn-primary {
        box-shadow: 0 4px 6px rgba(13,110,253,0.2);
    }

    .btn-outline-primary:hover {
        box-shadow: 0 4px 6px rgba(13,110,253,0.2);
    }
</style>
